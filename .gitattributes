# Default: treat files as text and normalize line endings to LF in the repo.
# Working-tree checkout uses LF (overrides core.autocrlf=true), so commits
# never show spurious whole-file diffs from CRLF/LF mismatches across platforms.
* text=auto eol=lf

# Explicit LF for source and text formats
*.java       text eol=lf
*.yml        text eol=lf
*.yaml       text eol=lf
*.xml        text eol=lf
*.md         text eol=lf
*.puml       text eol=lf
*.svg        text eol=lf
*.properties text eol=lf
*.txt        text eol=lf
.gitignore   text eol=lf
.gitattributes text eol=lf
LICENSE      text eol=lf

# Windows-only scripts keep CRLF
*.bat   text eol=crlf
*.cmd   text eol=crlf

# Binary files — never normalize
*.class  binary
*.jar    binary
*.db     binary
*.db-shm binary
*.db-wal binary
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.ico    binary
*.pdf    binary
